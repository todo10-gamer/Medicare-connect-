# =============================================
#   MediCare Connect - Environment Variables
# =============================================

# Server Port
PORT=5000

# MongoDB Atlas Connection String
# Replace <username>, <password>, and <dbname> with your actual details
MONGO_URI=mongodb://localhost:27017/medicare_db
# JWT Secret Key (use any long random string - keep it secret!)
JWT_SECRET=medicare_connect_super_secret_key_2024

# JWT Expiry Time
JWT_EXPIRES_IN=7d
